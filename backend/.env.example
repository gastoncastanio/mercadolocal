MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/mercadolocal
GEMINI_API_KEY=tu_gemini_api_key
JWT_SECRET=tu_jwt_secret_super_seguro
PORT=3001
NODE_ENV=development

# Mercado Pago Marketplace (obtener en mercadopago.com.ar/developers)
# Access token de TU cuenta (marketplace owner)
# Usado por: Fase 2 (marketplace) y Fase 3 (Radar del Centro - prepago)
MP_ACCESS_TOKEN=APP_USR-...
# Alias para Fase 3 (si no está, usa MP_ACCESS_TOKEN)
MERCADOPAGO_ACCESS_TOKEN=
MP_PUBLIC_KEY=APP_USR-...
# Para OAuth de vendedores (Split Payment)
# Crear aplicación tipo "Marketplace" en MP Developers
MP_APP_ID=tu_app_id
MP_CLIENT_SECRET=tu_client_secret
# Webhook secret para verificar firmas (configurar en MP Developers > Webhooks)
MP_WEBHOOK_SECRET=tu_webhook_secret
# Clave de encriptación para tokens MP en DB (si no se pone, usa JWT_SECRET)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MP_ENCRYPTION_KEY=

# Cloudinary (obtener en cloudinary.com)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# URLs
# FRONTEND_URL: orígenes permitidos por CORS (separados por coma). Poné acá tu
# dominio de producción exacto (ej: https://mercadolocal.vercel.app o tu dominio).
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Seguridad CORS: slug de tu equipo/cuenta de Vercel. Si lo seteás, solo se
# aceptan previews "mercadolocal-...-<scope>.vercel.app" (evita que alguien
# squattee un subdominio público y entre al CORS). Dejalo vacío y queda el patrón
# abierto (con aviso en logs).
VERCEL_SCOPE=

# Solo DEV LOCAL: permitir webhooks de Mercado Pago sin firma (cuando no tenés
# MP_WEBHOOK_SECRET para testear). JAMÁS poner en true en producción.
ALLOW_UNSIGNED_WEBHOOK=false

# Andreani - Cotizador de envios (obtener en andreani.com/desarrolladores)
ANDREANI_TOKEN=

# Email: Brevo (sin dominio) O Resend (con dominio verificado)
# Configura UNO u OTRO según tu caso:

# OPCIÓN A: BREVO (recomendado ahora, sin dominio verificado)
# - Gratis hasta 300 emails/día, 3000/mes
# - Solo necesita verificar el email FROM (clic en un link)
# - Obtener API key en https://app.brevo.com/settings/account/api
BREVO_API_KEY=xkeysib_...

# OPCIÓN B: RESEND (cuando compres dominio mercadolocal.com.ar)
# - 100 emails/día gratis
# - Requiere dominio verificado en resend.com/domains
# - Obtener API key en https://resend.com/api-keys
# RESEND_API_KEY=re_...

# EMAIL_FROM en ambos casos:
# - Con BREVO: usa tu email verificado (ej: admmercadolocal@gmail.com)
# - Con RESEND: usa dirección del dominio (ej: noreply@mercadolocal.com.ar)
EMAIL_FROM=MercadoLocal <admmercadolocal@gmail.com>

# Web Push Notifications (generar con: node -e "import('web-push').then(m => { const v = m.default.generateVAPIDKeys(); console.log('PUBLIC:', v.publicKey); console.log('PRIVATE:', v.privateKey); })")
# Las claves VAPID autentican el servidor cuando envía notificaciones push.
# NUNCA commitear VAPID_PRIVATE_KEY al repositorio.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admmercadolocal@gmail.com
